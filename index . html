7️⃣ Login Page (frontend/login.html)
<!DOCTYPE html>
<html>
<head>
    <title>Member Login</title>
</head>
<body>

<h2>Member Login</h2>

<input id="member_no" placeholder="Member Number">

<button onclick="login()">
Login
</button>

<script>

async function login(){

 const response = await fetch(
 "http://localhost:3000/api/auth/login",
 {
   method:"POST",
   headers:{
     "Content-Type":"application/json"
   },
   body:JSON.stringify({
     member_no:
     document.getElementById("member_no").value
   })
 });

 const data = await response.json();

 if(data.success){
   localStorage.setItem("member",data.member_no);
   window.location="dashboard.html";
 }

}

</script>

</body>
</html>
